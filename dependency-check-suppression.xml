<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.4.xsd">
    <suppress>
        <notes><![CDATA[False positive: Npgsql client library is not vulnerable to PostgreSQL server CVEs]]></notes>
        <filePath regex="true">.*Npgsql\.EntityFrameworkCore\.PostgreSQL\.dll</filePath>
        <cve>CVE-2021-3393</cve>
    </suppress>

    <suppress>
        <notes><![CDATA[Test-only dependency, not deployed]]></notes>
        <filePath regex="true">.*testcentric\.engine\.metadata\.dll</filePath>
        <cpe>cpe:/a:testcentric:testcentric-engine</cpe>
    </suppress>
</suppressions>