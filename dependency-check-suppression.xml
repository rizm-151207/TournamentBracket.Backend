<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <suppress>
        <notes><![CDATA[False positive: client library not vulnerable to PostgreSQL server CVEs]]></notes>
        <filePath regex="true">.*Npgsql\.EntityFrameworkCore\.PostgreSQL\.dll</filePath>
        <cve regex="true">.*</cve>
    </suppress>

    <suppress>
        <notes><![CDATA[Test-only dependency, not in production]]></notes>
        <filePath regex="true">.*testcentric\.engine\.metadata\.dll</filePath>
        <cve>CVE-2023-4914</cve>
    </suppress>
</suppressions>